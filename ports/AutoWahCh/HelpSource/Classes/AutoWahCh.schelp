Examples::

code::
(
{
	var src = LPF.ar(WhiteNoise.ar(0.2), 1200);
	AutoWahCh.ar(src, freq: 450, q: 5, gainDB: 6, attackMs: 1, releaseMs: 60, freqMod: 0.45) ! 2
}.play
)
::

code::
(
{
	var src = Decay2.ar(Impulse.ar(3), 0.002, 0.08) * PinkNoise.ar(0.5);
	AutoWahCh.ar(
		src,
		freq: MouseX.kr(200, 2000),
		q: 7,
		gainDB: 9,
		attackMs: 0.5,
		releaseMs: 80,
		freqMod: MouseY.kr(0, 1)
	) ! 2
}.play
)
::
