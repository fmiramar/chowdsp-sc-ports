Examples::

code::
(
{
	BaxandallCh.ar(
		PinkNoise.ar(0.08),
		bass: 0.75,
		treble: 0.35,
		mode: 0
	) ! 2
}.play
)
::

code::
(
{
	BaxandallCh.ar(
		Saw.ar(90, 0.08),
		bass: SinOsc.kr(0.09).range(0.2, 0.8),
		treble: LFTri.kr(0.07).range(0.15, 0.85),
		mode: 1
	) ! 2 * 0.5
}.play
)
::
