Examples::

code::
(
{
	var src = Saw.ar(110, 0.08);
	ChorusCh.ar(src, rate: 0.45, depth: 0.7, feedback: 0.2, mix: 0.6)
}.play
)
::

code::
(
{
	var src = PinkNoise.ar(0.06);
	ChorusCh.ar(src, rate: MouseX.kr(0.0, 1.0), depth: MouseY.kr(0.0, 1.0), feedback: 0.35, mix: 0.8)
}.play
)
::
