Examples::

code::
(
{
	var src = Decay2.ar(Impulse.ar(1.2), 0.001, 0.06) * WhiteNoise.ar(0.2);
	ConvDifusserCh.ar(src, src, 140)
}.play
)
::

code::
(
{
	var srcL = PinkNoise.ar(0.08) * Decay2.ar(Impulse.ar(2), 0.001, 0.04);
	var srcR = HPF.ar(srcL, 1200);
	ConvDifusserCh.ar(srcL, srcR, MouseX.kr(40, 500, 1))
}.play
)
::
