Examples::

code::
(
{
	var src = Decay2.ar(Impulse.ar(1.2), 0.01, 0.12) * WhiteNoise.ar(0.2);
	DelayBBCh.ar(src, delayTime: 0.07, filterFreq: 8500, feedback: 0.35, driveDB: 6, mix: 0.7) ! 2
}.play
)
::

code::
(
{
	var src = Saw.ar(110, 0.08);
	DelayBBCh.ar(
		src,
		delayTime: MouseX.kr(0.01, 0.18, 1),
		filterFreq: MouseY.kr(1200, 12000, 1),
		feedback: SinOsc.kr(0.08).range(-0.3, 0.6),
		driveDB: 3,
		mix: 0.65
	) ! 2
}.play
)
::
