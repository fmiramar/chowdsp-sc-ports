Examples::

code::
(
{
	LCOscCh.ar(
		Decay2.ar(Impulse.ar(2), 0.001, 0.02) * WhiteNoise.ar(0.6),
		freq: 220,
		closed: 1
	) ! 2
}.play
)
::

code::
(
{
	LCOscCh.ar(
		Impulse.ar(6, 0, 0.8),
		freq: SinOsc.kr(0.12).range(90, 700),
		closed: ToggleFF.kr(Impulse.kr(0.4))
	) ! 2 * 0.6
}.play
)
::
