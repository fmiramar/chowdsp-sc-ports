Examples::

code::
(
{
	MouseDriveCh.ar(
		Saw.ar(110, 0.1),
		distortion: 0.85,
		volume: 0.8
	) ! 2
}.play
)
::

code::
(
{
	var src = PinkNoise.ar(0.08);
	MouseDriveCh.ar(
		src,
		distortion: SinOsc.kr(0.08).range(0.2, 1.0),
		volume: 0.75
	) ! 2
}.play
)
::
