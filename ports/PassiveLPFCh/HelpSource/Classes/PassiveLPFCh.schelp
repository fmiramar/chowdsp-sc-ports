Examples::

code::
(
{
	PassiveLPFCh.ar(
		Saw.ar(110, 0.15),
		freq: 700
	) ! 2
}.play
)
::

code::
(
{
	PassiveLPFCh.ar(
		WhiteNoise.ar(0.12) * Decay2.ar(Impulse.ar(4), 0.005, 0.12),
		freq: SinOsc.kr(0.08).exprange(100, 8000)
	) ! 2 * 0.6
}.play
)
::
