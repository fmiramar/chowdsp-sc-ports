Examples::

code::
(
{
	var src = PinkNoise.ar(0.08);
	var lfo = SinOsc.kr(0.18) * 5;
	PhaserFBCh.ar(src, lfo, skew: 0.1, feedback: 0.6) ! 2
}.play
)
::

code::
(
{
	var src = Saw.ar([110, 111], 0.05);
	var lfo = LFTri.kr(0.07) * 5;
	PhaserFBCh.ar(src, lfo, skew: MouseX.kr(-1, 1), feedback: MouseY.kr(0, 0.95)) * 0.8
}.play
)
::
