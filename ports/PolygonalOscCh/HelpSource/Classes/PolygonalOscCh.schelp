Examples::

code::
(
{
	PolygonalOscCh.ar(freq: 220, order: 3.5, teeth: 0.0, gainDB: -18) ! 2
}.play
)
::

code::
(
{
	PolygonalOscCh.ar(
		freq: MouseX.kr(80, 2200, 1),
		order: SinOsc.kr(0.11).range(2.2, 8.0),
		teeth: MouseY.kr(0, 1),
		gainDB: -20
	) ! 2
}.play
)
::
