Examples::

code::
(
{
	var trig = Trig1.kr(Impulse.kr(0.5), 0.01);
	RNNCh.ar(Saw.ar(110, 0.2), randomize: trig, seed: 17)
}.play
)
::

code::
(
{
	var src = PinkNoise.ar(0.05);
	RNNCh.ar(src, src * 0.5, SinOsc.ar(40, 0, 0.1), 0, reset: Trig1.kr(Impulse.kr(0.25), 0.01), seed: 99) ! 2
}.play
)
::

code::
(
{
	var trig = Impulse.kr(2);
	var freq = Demand.kr(trig, 0, Dseq([36, 43, 48, 55, 53, 50].midicps, inf));
	var gate = Trig1.kr(trig, 0.2);
	var env = EnvGen.kr(Env.adsr(0.05, 0.35, 0.5, 0.3), gate);

	var sin = SinOsc.ar(freq, 0, 0.12);
	var tri = LFTri.ar(freq, 0, 0.12);
	var saw = Saw.ar(freq, 0.12);
	var pulse = Pulse.ar(freq, 0.5, 0.12);

	var cutoffRNN = RNNCh.ar(saw, pulse, tri, sin, seed: 19).tanh;
	var hpProbe = LocalIn.ar(1);
	var rqRNN = RNNCh.ar(hpProbe, sin, 0, 0, seed: 21).tanh;

	var src = Mix([saw, pulse * 0.6]);
	var cutoff = (freq * (4 + (cutoffRNN * 10)) * (0.7 + (env * 5))).clip(80, 8000);
	var rq = (0.12 + (rqRNN * 0.08)).clip(0.05, 0.5);
	var low = RLPF.ar(src, cutoff, rq);
	var high = HPF.ar(src, cutoff.max(80));

	LocalOut.ar(high * 0.5);
	(low * env * 0.4) ! 2
}.play
)
::
