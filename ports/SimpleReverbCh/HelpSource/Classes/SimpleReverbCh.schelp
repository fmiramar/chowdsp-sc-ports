Examples::

code::
(
{
	var src = Decay2.ar(Impulse.ar(1.5), 0.001, 0.05) * PinkNoise.ar(0.3);
	SimpleReverbCh.ar(src, src, diffusionTime: 120, fdnDelay: 110, fdnT60Low: 900, fdnT60High: 550, modAmount: 0.2, dryWet: 0.35)
}.play
)
::

code::
(
{
	var srcL = VarSaw.ar(70, 0, 0.3, 0.08);
	var srcR = Pulse.ar(105, 0.35, 0.06);
	SimpleReverbCh.ar(srcL, srcR, diffusionTime: MouseX.kr(40, 600), fdnDelay: 130, fdnT60Low: 1800, fdnT60High: 700, modAmount: MouseY.kr(0, 1), dryWet: 0.4)
}.play
)
::
