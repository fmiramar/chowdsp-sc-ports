Examples::

code::
(
{
	TR808HatCh.ar(
		WhiteNoise.ar(0.15) * Decay2.ar(Impulse.ar(8), 0.001, 0.02),
		freq: 6000,
		res: 0.55
	) ! 2
}.play
)
::

code::
(
{
	TR808HatCh.ar(
		Pulse.ar(12, 0.2, 0.12),
		freq: SinOsc.kr(0.09).exprange(2500, 12000),
		res: LFTri.kr(0.07).range(0.2, 0.9)
	) ! 2 * 0.5
}.play
)
::
