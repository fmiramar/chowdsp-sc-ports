Examples::

code::
(
{
	var src = Saw.ar(70, 0.25);
	TapeCh.ar(src, bias: 0.45, saturation: 0.55, drive: 0.7) ! 2
}.play
)
::

code::
(
{
	var src = PinkNoise.ar(0.08);
	TapeCh.ar(
		src,
		bias: MouseX.kr(0, 1),
		saturation: 0.6,
		drive: MouseY.kr(0, 1)
	) ! 2
}.play
)
::
