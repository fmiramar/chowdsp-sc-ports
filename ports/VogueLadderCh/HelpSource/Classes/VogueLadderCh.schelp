Examples::

code::
(
{
	VogueLadderCh.ar(
		WhiteNoise.ar(0.15),
		hpCutoff: 0.15,
		hpResonance: 0.2,
		lpCutoff: 0.7,
		lpResonance: 0.25,
		drive: 0.55
	)
}.play
)
::

code::
(
{
	var src = Saw.ar([70, 70.2], 0.08).sum;
	VogueLadderCh.ar(
		src,
		hpCutoff: LFTri.kr(0.05).range(0.0, 0.4),
		hpResonance: 0.15,
		lpCutoff: SinOsc.kr(0.07).range(0.25, 0.95),
		lpResonance: LFTri.kr(0.08).range(0.1, 0.85),
		drive: 0.7,
		oscillating: 1.0
	) ! 2 * 0.3
}.play
)
::
