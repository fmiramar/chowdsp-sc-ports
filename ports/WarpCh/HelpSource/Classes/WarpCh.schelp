Examples::

code::
(
{
	var src = Saw.ar(110 * [1, 1.005], 0.05).sum * 0.5;
	WarpCh.ar(src, cutoff: 0.58, heat: 0.45, width: 0.7, drive: 0.2, mode: 0) ! 2
}.play
)
::

code::
(
{
	var src = PinkNoise.ar(0.08);
	var cutoff = MouseX.kr(0.0, 1.0);
	var width = MouseY.kr(0.0, 1.0);
	WarpCh.ar(src, cutoff: cutoff, heat: 0.6, width: width, drive: 0.35, mode: 2) ! 2
}.play
)
::
