Examples::

code::
(
{
	WestCoastFoldCh.ar(SinOsc.ar(100, 0, 2.4)) ! 2 * 0.12
}.play
)
::

code::
(
{
	WestCoastFoldCh.ar(VarSaw.ar(60, 0, 0.2, 2.8)) ! 2 * 0.1
}.play
)
::
